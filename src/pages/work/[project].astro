---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  const projects = await getCollection("work");
  return projects.map((project) => ({
    params: { project: project.id },
  }));
}

const { project: projectId } = Astro.params;
const projects = await getCollection("work");
const entry = projects.find((p) => p.id === projectId);

if (!entry) {
  return Astro.redirect("/work");
}

const { Content } = await render(entry);
const {
  title,
  subtitle,
  description,
  techStack,
  screenshots,
  iconSrc,
  githubUrl,
  liveUrl,
} = entry.data;
---

<BaseLayout title={`${title} — Marjan Ilovski`} description={description}>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <!-- Back link -->
    <a
      href="/#work"
      class="inline-flex items-center gap-1.5 text-sm text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors mb-14"
    >
      <Icon name="bi:arrow-left" width="14" height="14" aria-hidden="true" />
      All projects
    </a>

    <!-- Header -->
    <div class="flex items-start gap-5 mb-10">
      {
        iconSrc && (
          <div class="shrink-0 flex items-center justify-center w-14 h-14 rounded-2xl bg-zinc-100 dark:bg-zinc-800 overflow-hidden">
            <img
              src={iconSrc}
              alt={title}
              width="36"
              height="36"
              class="w-9 h-9 object-contain"
            />
          </div>
        )
      }
      <div>
        <h1
          class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 mb-2"
        >
          {title}
        </h1>
        {
          subtitle && (
            <p class="text-base text-zinc-500 dark:text-zinc-400">{subtitle}</p>
          )
        }
      </div>
    </div>

    <!-- Hero screenshot -->
    {
      screenshots && screenshots.length > 0 && (
        <div class="mb-12 w-full aspect-video rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 shadow-sm">
          <img
            src={screenshots[0]}
            alt={`${title} screenshot`}
            class="w-full h-full object-cover"
          />
        </div>
      )
    }

    <!-- Markdown body -->
    <div class="prose">
      <Content />
    </div>

    <!-- Tech stack -->
    <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      <p
        class="text-xs font-mono uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-3"
      >
        Stack
      </p>
      <div class="flex flex-wrap gap-2">
        {
          techStack.map((tech) => (
            <span class="inline-flex items-center rounded-full border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-3 py-1 text-sm text-zinc-600 dark:text-zinc-400">
              {tech}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Screenshot gallery -->
    {
      screenshots && screenshots.length > 1 && (
        <div class="mt-10">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-4">
            Screenshots
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {screenshots.slice(1).map((src, i) => (
              <div class="rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 aspect-video">
                <img
                  src={src}
                  alt={`${title} screenshot ${i + 2}`}
                  class="w-full h-full object-cover"
                />
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Links -->
    {
      (githubUrl || liveUrl) && (
        <div class="flex flex-wrap gap-3 mt-10 pt-8 border-t border-zinc-200 dark:border-zinc-800">
          {githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-5 py-2.5 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:border-zinc-400 dark:hover:border-zinc-500 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-all shadow-sm"
            >
              <Icon
                name="bi:github"
                width="15"
                height="15"
                aria-hidden="true"
              />
              View source
            </a>
          )}
          {liveUrl && (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-zinc-900 dark:bg-zinc-100 px-5 py-2.5 text-sm font-medium text-white dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors shadow-sm"
            >
              <Icon
                name="bi:arrow-up-right"
                width="15"
                height="15"
                aria-hidden="true"
              />
              Live site
            </a>
          )}
        </div>
      )
    }
  </div>
</BaseLayout>
