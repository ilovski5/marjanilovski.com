---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout>
  <Hero />

  <!-- Section divider -->
  <hr class="border-t border-zinc-200 dark:border-zinc-800" />

  <!-- Work placeholder -->
  <section id="work" class="mx-auto max-w-5xl px-6 py-32 text-center">
    <p class="text-zinc-400 dark:text-zinc-500 text-sm font-mono">
      Work — coming next
    </p>
  </section>

  <!-- Section divider -->
  <hr class="border-t border-zinc-200 dark:border-zinc-800" />

  <!-- Resume placeholder -->
  <section id="resume" class="mx-auto max-w-5xl px-6 py-32 text-center">
    <p class="text-zinc-400 dark:text-zinc-500 text-sm font-mono">
      Resume — coming next
    </p>
  </section>
</BaseLayout>
