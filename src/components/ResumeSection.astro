---
import { Icon } from "astro-icon/components";
import { experience, education, certifications, skills } from "../data/resume";
---

<section
  id="resume"
  class="mx-auto max-w-5xl px-6 py-20 border-x border-zinc-200 dark:border-zinc-800"
>
  <!-- Section header -->
  <div class="mb-14">
    <p
      class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-3"
    >
      Resume
    </p>
    <h2
      class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      Experience & skills
    </h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <!-- Main column: Experience + Education -->
    <div class="lg:col-span-2 flex flex-col gap-14">
      <!-- Work Experience -->
      <div>
        <h3
          class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-7"
        >
          Work Experience
        </h3>
        <ol
          class="relative border-l border-zinc-200 dark:border-zinc-800 flex flex-col gap-10 ml-1"
        >
          {
            experience.map((entry) => (
              <li class="pl-7 relative">
                <span
                  class={`absolute -left-1.25 top-1.5 w-2.5 h-2.5 rounded-full bg-white dark:bg-zinc-950 border-2 ${entry.current ? "border-zinc-400 dark:border-zinc-500" : "border-zinc-300 dark:border-zinc-700"}`}
                />
                <span class="text-xs text-zinc-500 dark:text-zinc-400 font-mono mb-1 block">
                  {entry.dateRange}
                </span>
                <h4 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">
                  {entry.title}
                </h4>
                <p class="text-sm font-bold text-zinc-500 dark:text-zinc-400 mb-2">
                  {entry.organization}
                </p>
                {entry.description && (
                  <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
                    {entry.description}
                  </p>
                )}
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Education -->
      <div>
        <h3
          class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-7"
        >
          Education
        </h3>
        <ol
          class="relative border-l border-zinc-200 dark:border-zinc-800 flex flex-col gap-10 ml-1"
        >
          {
            education.map((entry) => (
              <li class="pl-7 relative">
                <span class="absolute -left-1.25 top-1.5 w-2.5 h-2.5 rounded-full bg-white dark:bg-zinc-950 border-2 border-zinc-300 dark:border-zinc-700" />
                <span class="text-xs text-zinc-500 dark:text-zinc-400 font-mono mb-1 block">
                  {entry.dateRange}
                </span>
                <h4 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">
                  {entry.title}
                </h4>
                <p class="text-sm font-bold text-zinc-500 dark:text-zinc-400 mb-2">
                  {entry.organization}
                </p>
                {entry.description && (
                  <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
                    {entry.description}
                  </p>
                )}
              </li>
            ))
          }
        </ol>
      </div>

      <!-- AWS Certificates -->
      <div>
        <h3
          class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-7"
        >
          Certifications
        </h3>
        <div class="flex flex-col gap-4">
          {
            certifications.map((cert) => (
              <div class="flex items-start gap-4 rounded-xl border border-zinc-200 dark:border-zinc-800 p-4">
                <div class="shrink-0 w-10 h-10 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 flex items-center justify-center">
                  {cert.icon ? (
                    <Icon
                      name={cert.icon}
                      width="24"
                      height="24"
                      aria-hidden="true"
                      class="w-6 h-6"
                    />
                  ) : (
                    <span class="text-lg">🏆</span>
                  )}
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
                    {cert.name}
                  </p>
                  <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-0.5">
                    {cert.issuer}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Download CV -->
      <!-- <div>
        <a
          href="/cv.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-5 py-2.5 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:border-zinc-400 dark:hover:border-zinc-500 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-all"
        >
          <Icon name="bi:download" width="14" height="14" aria-hidden="true" />
          Download CV
        </a>
      </div> -->
    </div>

    <!-- Sidebar: Skills -->
    <div class="flex flex-col gap-10">
      <!-- Skills -->
      <div>
        <h3
          class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6"
        >
          Skills
        </h3>
        <div class="flex flex-wrap gap-2">
          {
            skills.map((skill) => (
              <span class="inline-flex items-center rounded-full border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-2.5 py-0.5 text-xs text-zinc-500 dark:text-zinc-400">
                {skill}
              </span>
            ))
          }
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-zinc-200 dark:border-zinc-800"></div>

      <!-- Availability -->
      <div>
        <h3
          class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-4"
        >
          Availability
        </h3>
        <p
          class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4"
        >
          Open to freelance projects and consulting engagements. Prefer
          async-first, remote teams.
        </p>
        <a
          href="https://cal.com/marjanilovski"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
        >
          <span class="relative flex size-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex size-2 rounded-full bg-emerald-500"
            ></span>
          </span>
          Book a call
        </a>
      </div>
    </div>
  </div>
</section>
