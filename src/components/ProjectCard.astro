---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  title: string;
  description: string;
  techStack: string[];
  icon?: string;
  iconSrc?: string;
}

const { id, title, description, techStack, icon = "💻", iconSrc } = Astro.props;
---

<a
  href={`/work/${id}`}
  class="group flex flex-col rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6 hover:border-zinc-300 dark:hover:border-zinc-700 transition-all duration-200"
>
  <!-- Icon -->
  <div class="mb-4">
    <div
      class="flex items-center justify-center w-10 h-10 rounded-full bg-zinc-50 dark:bg-zinc-900 overflow-hidden select-none border border-zinc-200 dark:border-zinc-700"
    >
      {
        iconSrc ? (
          <img
            src={iconSrc}
            alt={title}
            width="24"
            height="24"
            class="w-6 h-6 object-contain"
          />
        ) : (
          <span class="text-lg">{icon}</span>
        )
      }
    </div>
  </div>

  <!-- Title -->
  <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
    {title}
  </h3>

  <!-- Description -->
  <p
    class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-5 flex-1"
  >
    {description}
  </p>

  <!-- Tech stack tags -->
  <div class="flex flex-wrap gap-1.5 mb-5">
    {
      techStack.map((tech) => (
        <span class="inline-flex items-center rounded-full border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 px-2.5 py-0.5 text-xs text-zinc-500 dark:text-zinc-400">
          {tech}
        </span>
      ))
    }
  </div>

  <!-- Arrow -->
  <div class="flex justify-end">
    <Icon
      name="bi:arrow-right-short"
      width="24"
      height="24"
      class="text-blue-500 dark:text-blue-400 -rotate-45 group-hover:rotate-0 transition-transform duration-200"
      aria-hidden="true"
    />
  </div>
</a>
