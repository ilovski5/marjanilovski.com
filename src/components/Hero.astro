---
// Hero section
import { Icon } from "astro-icon/components";
---

<section
  id="hero"
  class="mx-auto max-w-5xl px-6 pt-24 pb-28 flex flex-col items-center text-center"
>
  <!-- Avatar -->
  <div class="relative mb-7">
    <div
      class="w-30 h-30 rounded-full overflow-hidden ring-1 ring-zinc-200 dark:ring-zinc-700 shadow-md"
    >
      <img
        src="/avatar.png"
        alt="Marjan Ilovski"
        width="120"
        height="120"
        class="w-full h-full object-cover"
      />
    </div>
  </div>

  <!-- Name -->
  <h1
    class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 leading-tight mb-4"
  >
    Hi, I'm Marjan Ilovski — a full-stack developer and consultant.
  </h1>

  <!-- Tagline -->
  <p
    class="max-w-2xl text-base sm:text-lg lg:text-xl text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8"
  >
    I work with founders and teams to design, build, and ship web and mobile
    applications — from React frontends to AWS cloud infrastructure. Full
    ownership from idea to deployment.
  </p>

  <!-- Social links -->
  <div class="flex items-center gap-5 mb-10" aria-label="Social links">
    <!-- GitHub -->
    <a
      href="https://github.com/ilovski5"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
    >
      <Icon name="bi:github" width="24" height="24" aria-hidden="true" />
    </a>

    <!-- LinkedIn -->
    <a
      href="https://www.linkedin.com/in/marjan-ilovski/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
    >
      <Icon name="bi:linkedin" width="24" height="24" aria-hidden="true" />
    </a>
  </div>

  <!-- CTA button -->
  <a
    href="https://cal.com/marjanilovski"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2.5 rounded-lg bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 text-base font-medium px-6 py-3 shadow-sm hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors"
  >
    <!-- Pulsing green dot -->
    <span class="relative flex size-2.5">
      <span
        class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
      ></span>
      <span class="relative inline-flex size-2.5 rounded-full bg-emerald-500"
      ></span>
    </span>
    Open to work
  </a>
</section>
