---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<section
  id="work"
  class="mx-auto max-w-5xl px-6 py-20 border-x border-zinc-200 dark:border-zinc-800"
>
  <!-- Section header -->
  <div class="mb-12">
    <p
      class="text-xs font-mono uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-3"
    >
      Selected work
    </p>
    <h2
      class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      Things I've shipped
    </h2>
  </div>

  <!-- Project grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {
      projects.map((project) => (
        <ProjectCard
          id={project.id}
          title={project.data.title}
          description={project.data.description}
          techStack={project.data.techStack}
          icon={project.data.icon}
          iconSrc={project.data.iconSrc}
        />
      ))
    }
  </div>
</section>
